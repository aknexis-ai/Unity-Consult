{
  "name": "unity-consult-api",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready NestJS API for the Unity Consult PRD v7 implementation",
  "license": "UNLICENSED",
  "scripts": {
    "prestart": "npm run build",
    "start": "set NODE_PATH=./node_modules&& node dist/main.js",
    "start:dev": "set NODE_PATH=./node_modules&& ts-node-dev --respawn --transpile-only --ignore-watch node_modules --exit-child src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "seed": "ts-node-dev --transpile-only --exit-child scripts/seed.ts",
    "provider-check": "ts-node-dev --transpile-only --exit-child scripts/provider-check.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.21",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.21",
    "@nestjs/platform-socket.io": "^11.1.21",
    "@nestjs/swagger": "^11.4.3",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.21",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.10.1",
    "mongoose": "^9.6.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "razorpay": "^2.9.6",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.3",
    "rxjs": "^7.8.2",
    "swagger-ui-dist": "^5.32.6",
    "twilio": "^6.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.21",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.10",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}

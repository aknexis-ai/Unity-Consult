{
  "name": "unity-consult-workspace",
  "private": true,
  "description": "Workspace root for the Unity Consult frontend and backend apps",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run backend:providers && node scripts/dev.mjs",
    "build": "npm run backend:build && npm run frontend:build",
    "start": "npm run backend:providers && node scripts/start-production.mjs",
    "lint": "npm run backend:lint && npm run frontend:lint",
    "typecheck": "npm run backend:typecheck",
    "test": "npm run backend:test && npm run backend:test:e2e",
    "verify": "npm run lint && npm run typecheck && npm run backend:build && npm run backend:test && npm run backend:test:e2e && npm run frontend:build",
    "smoke:api": "node scripts/api-smoke.mjs",
    "frontend:dev": "npm run dev --workspace frontend",
    "frontend:build": "npm run build --workspace frontend",
    "frontend:start": "npm run start --workspace frontend",
    "frontend:lint": "npm run lint --workspace frontend",
    "backend:dev": "npm run start:dev --workspace backend",
    "backend:start": "npm run start --workspace backend",
    "backend:build": "npm run build --workspace backend",
    "backend:lint": "npm run lint --workspace backend",
    "backend:test": "npm run test --workspace backend",
    "backend:test:e2e": "npm run test:e2e --workspace backend",
    "backend:typecheck": "npm run typecheck --workspace backend",
    "backend:seed": "npm run seed --workspace backend",
    "backend:providers": "npm run provider-check --workspace backend"
  }
}
